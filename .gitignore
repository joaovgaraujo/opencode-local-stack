# --- Large downloaded artifacts (install.py fetches these; never commit) ---
# NOTE: gitignore does not support trailing inline comments - a "# ..." after
# a pattern on the same line becomes part of the pattern and silently stops
# matching anything. Keep comments on their own line.
# llama.cpp/: prebuilt llama.cpp release (CUDA/Vulkan/ROCm/CPU), downloaded from GitHub
llama.cpp/
# models/*.gguf: the model weights (downloaded from Hugging Face, or copied in by you)
models/*.gguf
models/*.bin
*.zip
*.tar.gz

# --- Generated per-machine artifacts (install.py (re)writes these every run) ---
run.ps1
run.sh
server.log
server.err
server.out
install-run.log
run.log
tests/vram.log
opencode-scratch/
RESULTS.md
# legacy name, kept ignored for anyone re-running an old checkout
RESULTS.md

# --- Python ---
__pycache__/
*.pyc
# macOS Rapid-MLX runtime created by install.py
.rapidmlx-venv/
.rapidmlx.pid

# --- OS / editor cruft ---
Thumbs.db
.DS_Store
*.swp

# --- Local agent/tooling state (not part of this project) ---
.claude/
