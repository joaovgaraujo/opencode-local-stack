# --- Large downloaded artifacts (install.ps1 fetches these; never commit) ---
llama.cpp/            # prebuilt llama.cpp CUDA binary (~1.1GB, downloaded from GitHub)
models/*.gguf         # the ~20GB model (downloaded from Hugging Face, or copied in by you)
models/*.bin
*.zip

# --- Runtime / test outputs generated by the scripts ---
server.log
server.err
server.out
install-run.log
run.log
tests/vram.log
opencode-scratch/
RESULTS.md       # per-machine result written by the installer on each run

# --- OS / editor cruft ---
Thumbs.db
.DS_Store
*.swp
